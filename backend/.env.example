# Backend HTTP/WebSocket port
PORT=4000

# Origin allowed for CORS + Socket.io. Match your frontend dev server.
FRONTEND_ORIGIN=http://localhost:3000

# AGENT_MODE=dummy | spawn
#   dummy → emits a synthetic stream (no external CLI required)
#   spawn → runs AGENT_CMD with AGENT_ARGS as a child process
AGENT_MODE=dummy

# Used only when AGENT_MODE=spawn
# AGENT_CMD=claude
# AGENT_ARGS=--print "summarize this repo"
